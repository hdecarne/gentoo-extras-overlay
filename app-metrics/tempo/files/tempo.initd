#!/sbin/openrc-run

configfile="${TEMPO_CONF:-/etc/tempo/tempo-local-config.yaml}"

command=/usr/bin/tempo
command_args="-config.file=${configfile} ${TEMPO_OPTS}"
command_background=yes
command_user=tempo:grafana
make_pidfile=yes
pidfile=/var/run/tempo.pid
start_stop_daemon_args="--chdir /var/lib/tempo --stdout /var/log/${SVCNAME}/${SVCNAME}.log --stderr /var/log/${SVCNAME}/${SVCNAME}.log"
